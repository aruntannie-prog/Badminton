{
  "expo": {
    "name": "BadmintonSmartScore",
    "slug": "badminton-smart-score",
    "version": "1.0.4",
    "orientation": "portrait",
    "icon": "./assets/icon.jpg",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.jpg",
      "resizeMode": "contain",
      "backgroundColor": "#121212"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.badminton.smartscore",
      "versionCode": 5,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.jpg",
        "backgroundColor": "#1A1A1A"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "scheme": "badminton-score",
    "plugins": [
      "expo-router",
      [
        "expo-sqlite",
        {
          "enableFts": true,
          "useSharedCache": true
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "175b28fb-37e2-4f20-96d8-d0d1e4794472"
      }
    },
    "owner": "aruntannie"
  }
}